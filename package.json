{
  "name": "grimoire",
  "productName": "Grimoire",
  "version": "0.2.5",
  "description": "World of Warcraft addon manager — CurseForge and Wago in one place",
  "main": "main.js",
  "author": "dontshome",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "verify-build": "node build/verify-build.js",
    "make-icon": "electron build/make-icon.js",
    "dist": "node build/pack.js clean",
    "dist:mac": "node build/pack.js clean",
    "dist:linux": "node build/pack.js clean",
    "dist:windows": "node build/pack.js clean",
    "dist:dad": "node build/pack.js dad",
    "dist:both": "node build/pack.js both"
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.dontshome.grimoire",
    "productName": "Grimoire",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "wago-ad-preload.js",
      "src/**/*",
      "ui/**/*",
      "build/icon.ico",
      "bundled.dat",
      "build-info.json"
    ],
    "asarUnpack": [
      "wago-ad-preload.js"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dontshome",
        "repo": "grimoire"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "category": "public.app-category.games",
      "identity": null,
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "category": "Game",
      "executableName": "grimoire"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Grimoire",
      "installerHeaderIcon": "build/icon.ico",
      "uninstallDisplayName": "Grimoire ${version}",
      "deleteAppDataOnUninstall": false
    }
  }
}
